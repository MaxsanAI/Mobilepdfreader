---
import type { Book } from '../lib/indexedDB';
import { formatReadingTime, estimateReadingTime } from '../lib/readerGenerator';

interface Props {
  book: Book;
}

const { book } = Astro.props;
const readingTime = formatReadingTime(estimateReadingTime(book.wordCount));
const cover = book.cover || '';
---

<div class="group relative animate-fade-in-up">
  <div
    class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
  >
    <!-- Cover -->
    <a href={`/reader?id=${book.id}`} class="block">
      <div class="relative aspect-[3/4] overflow-hidden bg-slate-100">
        {
          cover ? (
            <img
              src={cover}
              alt={book.title}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
          ) : (
            <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-primary-500 to-primary-800">
              <span class="text-3xl font-bold text-white">
                {book.title.split(/\s+/).slice(0, 2).map((w) => w[0]?.toUpperCase()).join('')}
              </span>
            </div>
          )
        }
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
      </div>
    </a>

    <!-- Info -->
    <div class="p-4">
      <h3 class="mb-1 truncate text-base font-semibold text-slate-800">
        <a href={`/reader?id=${book.id}`} class="hover:text-primary-600">{book.title}</a>
      </h3>
      <p class="mb-2 truncate text-xs text-slate-400">{book.fileName}</p>
      <p class="mb-3 text-xs text-slate-500">
        {readingTime} &middot; {book.wordCount.toLocaleString()} words
      </p>

      <!-- Actions -->
      <div class="flex items-center gap-2">
        <a
          href={`/reader?id=${book.id}`}
          class="flex-1 rounded-lg bg-primary-600 px-3 py-2 text-center text-xs font-semibold text-white transition hover:bg-primary-700 active:scale-95"
        >
          Continue Reading
        </a>
        <button
          data-delete-book={book.id}
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-slate-200 text-slate-400 transition hover:border-error-500 hover:text-error-500 active:scale-90"
          aria-label="Delete book"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>
