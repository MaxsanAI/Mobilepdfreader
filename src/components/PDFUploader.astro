---
---

<div
  id="pdf-uploader"
  class="relative rounded-2xl border-2 border-dashed border-slate-300 bg-white p-8 text-center transition-all duration-200 sm:p-12"
>
  <div class="pointer-events-none mb-5 flex justify-center">
    <div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary-50 text-primary-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 7.5m0 0L7.5 12M12 7.5v9" />
      </svg>
    </div>
  </div>

  <h3 class="mb-2 text-lg font-semibold text-slate-800">
    Drag &amp; drop your PDF here
  </h3>
  <p class="mb-5 text-sm text-slate-500">
    or click to browse files
  </p>

  <button
    id="upload-btn"
    type="button"
    class="inline-flex items-center gap-2 rounded-xl bg-primary-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:bg-primary-700 hover:shadow-md active:scale-95"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9m0 0-3 3m3-3 3 3M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5" />
    </svg>
    Select PDF
  </button>

  <input
    type="file"
    id="file-input"
    accept="application/pdf,.pdf"
    class="hidden"
  />

  <p class="mt-4 text-xs text-slate-400">
    Only .pdf files are supported. Your file never leaves your device.
  </p>
</div>

<div
  id="upload-error"
  class="mt-4 hidden rounded-xl bg-error-500/10 px-4 py-3 text-sm font-medium text-error-500"
>
</div>
